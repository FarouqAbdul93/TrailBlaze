@page "/"
<PageTitle>TrailBlaze - Find Your Trail</PageTitle>

<div class="home-container">
    <h1>🏔️ Find Your Perfect Trail</h1>
    <p>Discover walking and hiking trails across the UK</p>

    <div class="search-form">
        <div class="form-group">
            <label>Location</label>
            <input type="text"
                   @bind="location"
                   placeholder="e.g. Lake District, Peak District"
                   class="form-control" />
        </div>

        <div class="form-group">
            <label>Difficulty</label>
            <select @bind="difficulty" class="form-control">
                <option value="">All Difficulties</option>
                <option value="Easy">Easy</option>
                <option value="Moderate">Moderate</option>
                <option value="Hard">Hard</option>
            </select>
        </div>

        <button @onclick="SearchTrails" class="btn-search">
            Search Trails
        </button>
    </div>
</div>

@code {
    private string location = "";
    private string difficulty = "";

    private void SearchTrails()
    {
        // Will connect to API later
        Console.WriteLine($"Searching for {difficulty} trails near {location}");
    }
}