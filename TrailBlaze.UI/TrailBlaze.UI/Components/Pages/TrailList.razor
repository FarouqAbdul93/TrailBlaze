@page "/trails"
<PageTitle>TrailBlaze - Trails</PageTitle>

<div class="trail-list-container">
    <h1>🥾 Trails</h1>

    @if (trails == null)
    {
        <p>Loading trails...</p>
    }
    else if (!trails.Any())
    {
        <p>No trails found. Try a different search.</p>
    }
    else
    {
        <div class="trail-grid">
            @foreach (var trail in trails)
            {
                <div class="trail-card">
                    <h3>@trail.Name</h3>
                    <p>📍 @trail.Location</p>
                    <p>📏 @trail.DistanceMiles miles</p>
                    <p>💪 @trail.Difficulty</p>
                    <a href="/trails/@trail.TrailId">View Trail</a>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<TrailDto>? trails;

    protected override async Task OnInitializedAsync()
    {
        // Will connect to API later
        trails = new List<TrailDto>();
    }

    public class TrailDto
    {
        public int TrailId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Location { get; set; } = string.Empty;
        public double DistanceMiles { get; set; }
        public string Difficulty { get; set; } = string.Empty;
    }
}