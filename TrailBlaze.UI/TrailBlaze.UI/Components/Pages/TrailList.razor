@page "/trails"
<PageTitle>TrailBlaze - Trails</PageTitle>

<div class="trail-list-container">
    <h1>🥾 Trails</h1>

    @if (trails == null)
    {
        <p>Loading trails...</p>
    }
    else if (!trails.Any())
    {
        <p>No trails found. Try a different search.</p>
    }
    else
    {
        <div class="trail-grid">
            @foreach (var trail in trails)
            {
                <TrailCard Trail="trail" />
            }
        </div>
    }
</div>

@code {
    private List<TrailCard.TrailCardModel>? trails;

    protected override async Task OnInitializedAsync()
    {
        // Will connect to API later
        trails = new List<TrailCard.TrailCardModel>();
    }
}