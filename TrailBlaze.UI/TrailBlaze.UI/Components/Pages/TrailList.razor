@page "/trails"
@inject TrailService TrailService
@using TrailBlaze.UI.Services
<PageTitle>TrailBlaze - Trails</PageTitle>

<div class="trail-list-container">
    <h1>🥾 Trails</h1>

    @if (trails == null)
    {
        <p>Loading trails...</p>
    }
    else if (!trails.Any())
    {
        <p>No trails found. Try a different search.</p>
    }
    else
    {
        <div class="trail-grid">
            @foreach (var trail in trails)
            {
                <TrailCard Trail="new TrailCard.TrailCardModel
                           {
                               TrailId = trail.TrailId,
                               Name = trail.Name,
                               Location = trail.Location,
                               DistanceMiles = trail.DistanceMiles,
                               Difficulty = trail.Difficulty
                           }" />
                }
        </div>
    }
</div>

@code {
    private List<TrailDto>? trails;

    protected override async Task OnInitializedAsync()
    {
        trails = await TrailService.GetTrailsAsync();
    }
}